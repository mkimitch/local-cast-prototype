# Backend API. These values are read only by the Node server.
PORT=8787
CORS_ORIGIN=http://localhost:3000
DATABASE_PATH=data/localcast.sqlite
AI_PROVIDER=mock
AI_MODEL=mock-localcast
AI_BASE_URL=
AI_API_KEY=
GEMINI_API_KEY=

# Frontend. Only VITE_* values are exposed to the browser by Vite.
VITE_SERVICE_MODE=mock
VITE_API_BASE_URL=http://localhost:8787/api
